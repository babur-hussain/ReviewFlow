# Server
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://yourdomain.com
PUBLIC_BASE_URL=https://yourdomain.com

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/reviewflow?retryWrites=true&w=majority

# Firebase Admin SDK
# Use values from Firebase Console > Project settings > Service accounts.
# Local development can use GOOGLE_APPLICATION_CREDENTIALS instead of the three FIREBASE_* values.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
